# Comobot environment variables

# Gateway port (default: 18790)
COMOBOT_PORT=18790

# Secret key for credential encryption (auto-generated if not set)
# COMOBOT_SECRET_KEY=your-secret-key-here

# Telegram bot token (if using Telegram channel)
# TELEGRAM_BOT_TOKEN=

# OpenRouter API key
# OPENROUTER_API_KEY=
